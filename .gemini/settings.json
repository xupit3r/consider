{
  "mcpServers": {
    "clojure-mcp": {
      "command": "clojure",
      "args": [
        "-Tmcp",
        "start",
        ":config-profile",
        "default"
      ]
    },
    "fetch": {
      "command": "/home/joe/.local/bin/uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/joe/code/consider"
      ]
    },
    "git": {
      "command": "/home/joe/.local/bin/uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "/home/joe/code/consider"
      ]
    }
  },
  "experimental": {
    "enableAgents": true
  }
}
